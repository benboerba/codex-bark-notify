# Bark push endpoint.
# Official Bark usually looks like:
# BARK_ENDPOINT="https://api.day.app/your-bark-key"
# Self-hosted Bark can also be used.
BARK_ENDPOINT="https://api.day.app/your-bark-key"

# Default notification:
# title = "Codex 完成思考：会话名"
# body  = "会话「会话名」已结束，可以回来查看结果了。"
BARK_TITLE_PREFIX="Codex 完成思考"

# Uncomment these two lines if you want fixed text and do not want session names.
# BARK_TITLE="Codex 完成思考"
# BARK_BODY="当前回合已结束，可以回来查看结果了。"

BARK_GROUP="Codex"
BARK_SOUND="bell"

# Skip repeated notifications for the same session within this many seconds.
BARK_DEDUP_SECONDS="120"
